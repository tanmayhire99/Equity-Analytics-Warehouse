# Copy this file to .env and adjust values. Never commit .env.

# --- Database -------------------------------------------------------------
# Which target to use: 'local' (default) -> DATABASE_URL, 'supabase' -> DATABASE_URL_SUPABASE.
DB_TARGET=local

# Local PostgreSQL via Docker (see README "Setup").
DATABASE_URL=postgresql://equity_user:equity_pass@localhost:5433/equity_db

# Supabase (Session pooler). URL-encode special chars in the password (@ -> %40).
# DATABASE_URL_SUPABASE=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# --- Pipeline config ------------------------------------------------------
FETCH_LOOKBACK_DAYS=7      # window pulled on each incremental run
BACKFILL_DAYS=90          # window pulled by run_backfill.py
LOG_LEVEL=INFO

# --- Daily schedule (IST) -------------------------------------------------
SCHEDULE_HOUR=16          # 16:00 IST, shortly after the 15:30 NSE close
SCHEDULE_MINUTE=0
TIMEZONE=Asia/Kolkata

# --- Data-quality monitoring ----------------------------------------------
# Thresholds for `python run_quality.py` / the equity_data_quality DAG / the
# post-ingest check in the scheduler. See pipeline/quality.py.
MAX_STALENESS_DAYS=5              # freshness fails if latest trade date older than this
MIN_FACT_ROWS=100                # row-volume floor (warehouse empty/truncated guard)
QUALITY_ERROR_WARN_THRESHOLD=100 # WARN (non-fatal) above this many error_log rows
# Optional Slack-compatible incoming webhook; set to POST an alert on FAIL.
# QUALITY_ALERT_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ
