# Copy this file to .env and adjust values. Never commit .env.

# --- Database -------------------------------------------------------------
# Local PostgreSQL via Docker (see README "Local PostgreSQL (Docker)").
DATABASE_URL=postgresql://equity_user:equity_pass@localhost:5433/equity_db
# Supabase (cloud PostgreSQL) — switch by swapping this line, no code changes:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# --- Pipeline config ------------------------------------------------------
FETCH_LOOKBACK_DAYS=7      # window pulled on each incremental run
BACKFILL_DAYS=90          # window pulled by run_backfill.py
LOG_LEVEL=INFO

# --- Daily schedule (IST) -------------------------------------------------
SCHEDULE_HOUR=16          # 16:00 IST, shortly after the 15:30 NSE close
SCHEDULE_MINUTE=0
TIMEZONE=Asia/Kolkata
